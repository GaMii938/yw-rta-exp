<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>妖怪ウォッチRTA EXP Tracker</title>

<style>
body{
    font-family:sans-serif;
    margin:0;
    padding:15px;
    background:#111;
    color:white;
}

h1{
    text-align:center;
}

.card{
    background:#1e1e1e;
    border-radius:12px;
    padding:15px;
    margin-bottom:15px;
}

.stats{
    font-size:18px;
    line-height:1.8;
}

.multiplier{
    display:flex;
    gap:10px;
    margin-top:10px;
}

.multiplier button{
    flex:1;
}

.grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:10px;
}

button{
    border:none;
    border-radius:10px;
    padding:15px;
    font-size:16px;
    cursor:pointer;
}

.expBtn{
    background:#2b2b2b;
    color:white;
}

.control{
    background:#333;
    color:white;
}

.reset{
    background:#7a1f1f;
    color:white;
}

.active{
    outline:3px solid orange;
}

#history{
    max-height:250px;
    overflow:auto;
    font-size:14px;
}
</style>
</head>
<body>

<h1>妖怪ウォッチRTA EXP Tracker</h1>

